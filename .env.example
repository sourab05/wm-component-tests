# =============================================================================
# WaveMaker Studio Credentials (required)
# =============================================================================
STUDIO_BASE_URL=https://stage-studio.wavemakeronline.com/
PROJECT_ID=WMPRJ2c9180879b8c2464019b8ca78bde000e
STUDIO_PROJECT_ID=proj-71823062-f485-4f48-8b76-8227cd1a991d

STUDIO_USERNAME=your-email@wavemaker.com
STUDIO_PASSWORD=your-password

# Auth method: auto-detected from URL, or force with "google" / "wavemaker" / "platformdb"
# AUTH_METHOD=wavemaker

# Google OAuth (only for stage-platform.wavemaker.ai)
# GOOGLE_EMAIL=your-google-email@wavemaker.com
# GOOGLE_PASSWORD=your-google-password
# GOOGLE_TOTP_SECRET=your-totp-secret

# Pre-captured cookie (skip login entirely if set)
# STUDIO_COOKIE=auth_cookie=...; JSESSIONID=...

# =============================================================================
# Studio API Paths (defaults usually work)
# =============================================================================
# STUDIO_LOGIN_PATH=/login/authenticate
# CANVAS_PATH=s/page/Main?project-id=${PROJECT_ID}

# =============================================================================
# Test Configuration
# =============================================================================
# Widget to test (passed via CLI or env)
# WIDGET_NAME=Button

# Application name to open in Studio
APPLICATION_NAME=FORM

# =============================================================================
# AWS S3 (optional, for report uploads)
# =============================================================================
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret
# AWS_REGION=us-west-2
# S3_BUCKET_NAME=wm-qa-automation
